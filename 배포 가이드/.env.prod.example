# EnglishAgentHub production env example

# Required
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes
API_KEY_SECRET=change-this-to-a-long-random-secret
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Optional OpenAI model settings
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_TRANSLATION_MODEL=gpt-5-nano
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin

# Kakao OAuth, if enabled
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://english.dxline-tallent.com/api/kakao/oauth/callback

# S3 upload, if enabled
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=english-agent-hub-front
AWS_S3_REGION=ap-northeast-2
AWS_S3_PREFIX=english-agent-hub

# CORS, after SecurityConfig is changed to read this value
ALLOWED_ORIGIN=https://english.dxline-tallent.com
